{
  "branches": ["master"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
       "@semantic-release/release-notes-generator",
       {
        "preset": "conventionalcommits"
       }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "docs/CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "changelogFile": "docs/CHANGELOG.md",
        "pkgRoot": "dist"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": "dist/*.tgz"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "echo //npm.pkg.github.com/:_authToken=$GITHUB_TOKEN > /tmp/github.npmrc && npm whoami --userconfig /tmp/github.npmrc --registry https://npm.pkg.github.com/",
        "publishCmd": "npm publish dist --userconfig /tmp/github.npmrc --tag v${nextRelease.version} --registry https://npm.pkg.github.com/ --no-git-tag-version",
        "successCmd": "rm -f /tmp/github.npmrc",
        "failCmd": "rm -f /tmp/github.npmrc"
      }
    ]
  ],
  "dryRun": false,
  "debug": false
}
