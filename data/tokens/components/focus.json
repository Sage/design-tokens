{
  "focus": {
    "bg": {
      "$type": "color",
      "$value": "{mode.color.action.focus.withDefaultAlt}"
    },
    "borderalt": {
      "$type": "color",
      "$value": "{mode.color.action.focus.default}"
    },
    "border": {
      "$type": "color",
      "$value": "{mode.color.action.focus.withDefault}"
    },
    "label": {
      "$type": "color",
      "$value": "{mode.color.action.focus.txt}"
    },
    "inverse": {
      "bg": {
        "$type": "color",
        "$value": "{mode.color.action.focus.inverse.withDefaultAlt}"
      },
      "borderalt": {
        "$type": "color",
        "$value": "{mode.color.action.focus.inverse.default}"
      },
      "border": {
        "$type": "color",
        "$value": "{mode.color.action.focus.inverse.withDefault}"
      },
      "label": {
        "$type": "color",
        "$value": "{mode.color.action.focus.inverse.txt}"
      }
    },
    "shadow": {
      "default": {
        "$type": "boxShadow",
        "$value": [
          {
            "x": "0",
            "y": "0",
            "blur": "0",
            "spread": "2",
            "color": "{focus.borderalt}",
            "type": "dropShadow"
          },
          {
            "x": "0",
            "y": "0",
            "blur": "0",
            "spread": "4",
            "color": "{focus.border}",
            "type": "dropShadow"
          }
        ]
      },
      "inner": {
        "$type": "boxShadow",
        "$value": [
          {
            "x": "0",
            "y": "0",
            "blur": "0",
            "spread": "2",
            "color": "{focus.border}",
            "type": "innerShadow"
          },
          {
            "x": "0",
            "y": "0",
            "blur": "0",
            "spread": "4",
            "color": "{focus.borderalt}",
            "type": "innerShadow"
          }
        ]
      }
    }
  }
}