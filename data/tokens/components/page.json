    "typography": {
      "responsive": {
        "H1": {
          "$type": "typography",
          "$value": "{global.typography.responsive.heading.M}"
        },
        "H2": {
          "$type": "typography",
          "$value": "{global.typography.responsive.heading.S}"
        },
        "H3": {
          "$type": "typography",
          "$value": "{global.typography.responsive.heading.XS}"
        },
        "H4": {
          "$type": "typography",
          "$value": "{global.typography.responsive.subheading.M}"
        },
        "p": {
          "typical": {
            "$type": "typography",
            "$value": "{global.typography.responsive.body.S}"
          },
          "large": {
            "$type": "typography",
            "$value": "{global.typography.responsive.body.M}"
          }
        },
        "hero": {
          "h1": {
            "$type": "typography",
            "$value": "{global.typography.responsive.display.L}"
          },
          "h2": {
            "$type": "typography",
            "$value": "{global.typography.responsive.display.M}"
          }
        }
      },
      "adaptive": {
        "H1": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{global.fontFamilies.sage-text}",
            "fontWeight": "{primitives.fontWeights.bold}",
            "lineHeight": "{primitives.lineHeights.400}",
            "fontSize": "{global.fontSize.adaptive.heading.step5}"
          }
        },
        "H2": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{global.fontFamilies.sage-text}",
            "fontWeight": "{primitives.fontWeights.bold}",
            "lineHeight": "{primitives.lineHeights.400}",
            "fontSize": "{global.fontSize.adaptive.heading.step4}"
          }
        },
        "H3": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{global.fontFamilies.sage-text}",
            "fontWeight": "{primitives.fontWeights.bold}",
            "lineHeight": "{primitives.lineHeights.400}",
            "fontSize": "{global.fontSize.adaptive.heading.step3}"
          }
        },
        "H4": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{global.fontFamilies.sage-text}",
