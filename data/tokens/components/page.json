          "$type": "spacing",
          "$value": "{global.space.macro.XS} / 4"
        },
        "XXS": {
          "$type": "spacing",
          "$value": "{global.space.macro.XS} / 2"
        },
        "XS": {
          "$type": "spacing",
          "$value": "{global.space.macro.XS}"
        },
        "S": {
          "$type": "spacing",
          "$value": "{global.space.macro.M}"
        },
        "M": {
          "$type": "spacing",
          "$value": "{global.space.macro.L}"
        },
        "L": {
          "$type": "spacing",
          "$value": "{global.space.macro.XL}"
        },
        "XL": {
          "$type": "spacing",
          "$value": "{global.space.macro.XL} * 2"
        }
      },
      "xg": {
