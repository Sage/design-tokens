    "color": {
      "inverse": {
        "bg-default": {
          "$type": "color",
          "$value": "{modes.color.generic.backdrop.inverse.nought}"
        },
        "bg-alt": {
          "$type": "color",
          "$value": "{modes.color.generic.backdrop.inverse.faint}"
        },
        "text-alt": {
          "$type": "color",
          "$value": "{modes.color.generic.content.inverse.moderate}",
          "$description": "for subheadings etc"
        },
        "text-default": {
          "$type": "color",
          "$value": "{modes.color.generic.content.inverse.harsh}",
          "$description": "for headings, paragraph text etc "
        }
      },
      "standard": {
        "bg-default": {
          "$type": "color",
          "$value": "{modes.color.generic.backdrop.standard.nought}"
        },
        "bg-alt": {
          "$type": "color",
          "$value": "{modes.color.generic.backdrop.standard.faint}"
        },
        "text-alt": {
          "$type": "color",
          "$value": "{modes.color.generic.content.standard.moderate}",
          "$description": "for subheadings etc"
        },
        "text-default": {
          "$type": "color",
          "$value": "{modes.color.generic.content.standard.harsh}",
          "$description": "for headings, paragraph text etc "
        }
      }
