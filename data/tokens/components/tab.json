        "$type": "sizing",
        "$value": "{global.size.macro.M}",
        "$description": "Anchor nav, M Tab"
      },
      "L": {
        "$type": "sizing",
        "$value": "{global.size.macro.L}",
        "$description": "L tab"
      },
      "shadow": {
        "arrow": {
          "$type": "sizing",
          "$value": "{global.size.micro.M}",
          "$description": "Shadow width for linear gradient shadow on repsonsive tab arrows."
        }
      },
      "baseline": {
        "M": {
          "$type": "sizing",
          "$value": "{global.size.micro.XXS}",
          "$description": "Thickness of baseline."
        },
        "L": {
          "$type": "sizing",
