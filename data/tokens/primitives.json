{
  "primitives": {
    "colors": {
      "black": {
        "$type": "color",
        "$value": "#000000",
        "$description": "Base color for different text opacities.\nUsed as a mixer in the mid theming layer for hover states, active states etc.\nDividers and table headers.\nBase color for secondary, Tertiary and Subtle buttons.\nBase color for Input borders.\nFocus internal border."
      },
      "blue": {
        "$type": "color",
        "$value": "#0071c3",
        "$description": "Base information status color for on light surface information messages, toasts and pills. Luminosity 46.8."
      },
      "blueBright": {
        "$type": "color",
        "$value": "#008AEA",
        "$description": "Base information status color for on dark surface information messages, toasts and pills. Luminosity 56.2."
      },
      "brilliantGreen": {
        "$type": "color",
        "$value": "#00D639",
        "$description": "Sage Logo color\nPrimary buttons on dark backgrounds"
      },
      "emerald": {
        "$type": "color",
        "$value": "#00811F",
        "$description": "Primary buttons on light backgrounds. Was #008047 Jade. Luminosity 46.8."
      },
      "jade": {
        "$type": "color",
        "$value": "#007E45",
        "$description": "Legacy green used on old product theme"
      },
      "emeraldLight": {
        "$type": "color",
        "$value": "#009024",
        "$description": "AAA text on 000000 bgs. This is deliberately NOT named bright. Luminosity 51.9."
      },
      "green": {
        "$type": "color",
        "$value": "#008047",
        "$description": "Base success status color for on light surface  messages, toasts and pills. Was #00821e, now Jade #008047. Luminosity 46.8."
      },
      "greenBright": {
        "$type": "color",
        "$value": "#009b57",
        "$description": "Base success status color for on dark surface  messages, toasts and pills. Luminosity 51.9. (Was #009C26, now derivative of Jade)"
      },
      "orange": {
        "$type": "color",
        "$value": "#BA4E00",
        "$description": "Base warning status color for on light surface  messages, toasts and pills. Warning text on text inputs. Luminosity 46.8."
      },
      "orangeBright": {
        "$type": "color",
        "$value": "#DF6000",
        "$description": "Base warning status color for on dark surface  messages, toasts and pills.\nWarning text in inputs on dark surfaces.\nLuminosity 56.2."
      },
      "gold": {
        "$type": "color",
        "$value": "#FFB500",
        "$description": "Outer focus border."
      },
      "storm": {
        "$type": "color",
        "$value": "#6f6f6f",
        "$description": "Base neutral status color for on light surface  messages, toasts and pills. Luminosity 46.8."
      },
      "navy": {
        "$type": "color",
        "$value": "#00293F",
        "$description": "old product color for monochrome components. eg page backgrounds and minor buttons "
      },
      "stormBright": {
        "$type": "color",
        "$value": "#878787",
        "$description": "Base neutral status color for on dark surface  messages, toasts and pills. Luminosity 56.2."
      },
      "red": {
        "$type": "color",
        "$value": "#CB374B",
        "$description": "Base error status color for on light surface  messages, toasts and pills.\nError text in inputs on dark surfaces.\nAAA against FFFFFF bg. Used in most components, on light bgs.\nLuminosity 46.8.\n"
      },
      "redBright": {
        "$type": "color",
        "$value": "#e95164",
        "$description": "Base error status color for on dark surface  messages, toasts and pills.\nUsed in feedback components, on dark bg (meets SHAPE accessibility reqs).\nLuminosity 56.2."
      },
      "redLight": {
        "$type": "color",
        "$value": "#E13E54",
        "$description": "Base error status color for on light surface  messages, toasts and pills.\nError text in inputs on dark surfaces.\nUsed in Buttons on dark bg (meets text accessibility reqs).\nLuminosity 51.9."
      },
      "teal": {
        "$type": "color",
        "$value": "#007c7b",
        "$description": "Alternative colour with no semantic meaning. Used in progress tracker.\nAAA against FFFFFF bg. \nLuminosity 46.8."
      },
      "transparent": {
        "$extensions": {
          "studio.tokens": {
            "modify": {
              "type": "alpha",
              "value": "0",
              "space": "lch"
            }
          }
        },
        "$type": "color",
        "$value": "rgba(0,0,0,0)",
        "$description": "For transparent backgrounds and borders."
      },
      "white": {
        "$type": "color",
        "$value": "#FFFFFF",
        "$description": "Surface backgrounds.\nText colors on buttons and on dark backgrounds.\nUsed as a mixer in the mid theming layer for hover states, active states etc."
      },
      "aiH": {
        "$type": "color",
        "$value": "linear-gradient(90deg, #13A038 0%, #149197 40%, #A87CFB 90%)",
        "$description": "AI buttons on light backgrounds."
      },
      "aiV": {
        "$type": "color",
        "$value": "linear-gradient(180deg, #13A038 0%, #149197 40%, #A87CFB 90%)",
        "$description": "AI buttons on light backgrounds."
      },
      "lightAiH": {
        "$type": "color",
        "$value": "linear-gradient(90deg, #00D639 0%, #00D6DE 40%, #9D60FF 90%)",
        "$description": "AI buttons on dark backgrounds."
      },
      "lightAiV": {
        "$type": "color",
        "$value": "linear-gradient(180deg, #00D639 0%, #00D6DE 40%, #9D60FF 90%)",
        "$description": "Nudge message border"
      }
    },
